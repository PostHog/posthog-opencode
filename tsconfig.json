{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noEmit": true,
        "declaration": true,
        "isolatedModules": true,
        "resolveJsonModule": true
    },
    "include": ["src"]
}
