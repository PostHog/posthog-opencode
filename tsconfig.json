{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noEmit": true,
        "declaration": true,
        "declarationDir": "./dist",
        "outDir": "./dist",
        "rootDir": "./src",
        "isolatedModules": true,
        "resolveJsonModule": true,
        "types": ["bun-types"]
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"]
}
